{
  "rules": {
    ".read": true,
    ".write": true,
    "pigeons": {
      "$userId": {
        ".read": "$userId === auth.uid || auth != null",
        ".write": "$userId === auth.uid || auth != null"
      }
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || auth != null",
        ".write": "$uid === auth.uid || auth != null"
      }
    },
    "public": {
      ".read": true,
      ".write": true
    }
  }
}
